{
  "name": "cardgame",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:bench": "vitest bench src/test/ai-perf.bench.ts --outputJson .ai-bench-report.json && node scripts/check-ai-bench.mjs .ai-bench-report.json",
    "generate:card-art": "node scripts/generate-card-art.mjs",
    "generate:photoreal-card-art": "node scripts/generate-photoreal-card-art.mjs"
  },
  "devDependencies": {
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "phaser": "^4.1.0"
  }
}
